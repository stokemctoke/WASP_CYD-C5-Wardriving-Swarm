# W.A.S.P. Worker configuration
# Place on the worker's own SD card as /worker.cfg
# Lines starting with # are comments. No spaces around = signs.

# RGB LED
ledEnabled=true          # true/false or 1/0 — disables all LED output when false
ledBrightness=40         # 0–255 — 40 is comfortably visible without being blinding
ledType=ws2812           # ws2812  → addressable WS2812B/SK6812 on D0 (GPIO3) via RMT
                         # rgb4pin → common-cathode 4-pin RGB: R=D0, G=D4, B=D5

# LED event colours and timing — format: RRGGBB,flashes,onMs,offMs
# Omit any line to keep the compiled-in default.
# flashes=0 on ledGPSAcquire and ledConnecting means continuous toggle (those are loop-based).
#ledBoot=FFFFFF,3,50,50          # white  — startup / config loaded
#ledGPSAcquire=FF3C00,0,400,400  # amber  — acquiring GPS, no fix yet (continuous)
#ledGPSFound=64FF00,4,400,300    # lime   — GPS fix first acquired
#ledGPSFix=64FF00,2,150,100      # lime   — GPS has fix
#ledScanCycle=FFDC00,1,100,0     # yellow — new network / scan cycle
#ledConnecting=FF6400,0,200,200  # orange — WiFi connecting (continuous)
#ledSyncOK=00FF00,2,150,100      # green  — sync / WiFi OK
#ledSyncFail=FF0000,3,80,80      # red    — sync failed
#ledTooBig=FF6400,4,80,80        # orange — file too big
#ledLowHeap=FF0000,1,400,0       # red    — low heap
#ledDronePulse=0050FF,2,200,100  # blue   — drone connection pulse
#ledHeartbeat=FF69B4,2,80,80     # pink   — heartbeat / idle
